<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="mercas_keys.MercasTopBar">
        <div class="o_mercas_topbar_systray d-flex align-items-center gap-1 px-2">

            <t t-foreach="modes" t-as="mode" t-key="mode.fkey">
                <button
                    class="btn btn-sm btn-outline-secondary o_mercas_nav_btn"
                    t-on-click="() => this.openMode(mode)"
                    t-att-title="mode.fkey + ' · ' + mode.label"
                >
                    <span class="o_mercas_nav_fkey"><t t-esc="mode.fkey"/></span>
                    <span class="o_mercas_nav_label"><t t-esc="mode.label"/></span>
                </button>
            </t>

            <div class="o_mercas_separator"/>

            <button
                class="btn btn-sm btn-outline-success o_mercas_nav_btn"
                t-on-click="() => this.addLine()"
                title="Ins · Nueva línea de producto"
            >
                <span class="o_mercas_nav_fkey">Ins</span>
                <span class="o_mercas_nav_label">Nueva línea</span>
            </button>

        </div>
    </t>

    <t t-name="mercas_keys.MercasUnifiedScreen">
        <div class="o_mercas_unified_screen d-flex flex-column align-items-center justify-content-center h-100">
            <div class="d-flex flex-wrap gap-4 justify-content-center">
                <t t-foreach="modes" t-as="mode" t-key="mode.fkey">
                    <button class="btn btn-outline-primary o_mercas_mode_btn"
                            t-on-click="() => this.openMode(mode)"
                            t-att-title="mode.fkey">
                        <div class="o_mercas_fkey"><t t-esc="mode.fkey"/></div>
                        <div class="o_mercas_label"><t t-esc="mode.label"/></div>
                    </button>
                </t>
            </div>
        </div>
    </t>

</templates>
