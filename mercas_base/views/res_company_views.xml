<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_company_form_mercas" model="ir.ui.view">
        <field name="name">res.company.form.mercas</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Mercas" name="mercas">
                    <group>
                        <group string="Almacén">
                            <field name="mercas_customer_location_id"/>
                        </group>
                        <group string="Compras">
                            <field name="purchase_lot_autocomplete" widget="toggle"/>
                            <field name="origin_country" widget="toggle"/>
                            <field name="origin_state" widget="toggle"/>
                            <field name="origin_filter" widget="toggle"/>
                        </group>
                        <group string="Envases">
                            <field name="box_purchase_type_id"/>
                            <field name="box_categ_ids" widget="many2many_tags"/>
                        </group>
                        <group string="Contabilidad">
                            <field name="compensation_journal_id"/>
                            <field name="mercas_margin"/>
                            <field name="auto_confirm_supplier_invoice" widget="toggle"/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

</odoo>
