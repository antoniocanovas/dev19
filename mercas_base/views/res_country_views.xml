<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- res.country -->
    <record id="view_country_tree_mercas" model="ir.ui.view">
        <field name="name">res.country.list.mercas</field>
        <field name="model">res.country</field>
        <field name="inherit_id" ref="base.view_country_tree"/>
        <field name="arch" type="xml">
            <field name="code" position="after">
                <field name="mercas_origin"/>
            </field>
        </field>
    </record>

    <record id="view_country_form_mercas" model="ir.ui.view">
        <field name="name">res.country.form.mercas</field>
        <field name="model">res.country</field>
        <field name="inherit_id" ref="base.view_country_form"/>
        <field name="arch" type="xml">
            <group name="phone_vat_settings" position="after">
                <group name="mercas_settings" string="Mercas">
                    <field name="mercas_origin"/>
                </group>
            </group>
        </field>
    </record>

    <!-- res.country.state (standalone) -->
    <record id="view_country_state_tree_mercas" model="ir.ui.view">
        <field name="name">res.country.state.list.mercas</field>
        <field name="model">res.country.state</field>
        <field name="inherit_id" ref="base.view_country_state_tree"/>
        <field name="arch" type="xml">
            <field name="code" position="after">
                <field name="mercas_origin"/>
            </field>
        </field>
    </record>

    <record id="view_country_state_form_mercas" model="ir.ui.view">
        <field name="name">res.country.state.form.mercas</field>
        <field name="model">res.country.state</field>
        <field name="inherit_id" ref="base.view_country_state_form"/>
        <field name="arch" type="xml">
            <field name="country_id" position="after">
                <field name="mercas_origin"/>
            </field>
        </field>
    </record>

    <!-- Columna mercas_origin en el One2many de estados dentro del formulario de país -->
    <record id="view_country_form_states_mercas" model="ir.ui.view">
        <field name="name">res.country.form.states.mercas</field>
        <field name="model">res.country</field>
        <field name="inherit_id" ref="base.view_country_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state_ids']/list/field[@name='code']" position="after">
                <field name="mercas_origin"/>
            </xpath>
        </field>
    </record>

</odoo>
