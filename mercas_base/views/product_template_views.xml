<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_product_template_form_mercas" model="ir.ui.view">
        <field name="name">product.template.form.mercas</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- Inserta después del div que contiene qty_available (padre de uom_span) -->
            <xpath expr="//span[@name='uom_span']/.." position="after">
                <field name="mercas_box_categ_ids" invisible="1"/>
                <field name="box_product_id"
                       invisible="not is_storable"
                       domain="[('categ_id', 'in', mercas_box_categ_ids)]"/>
            </xpath>
        </field>
    </record>

</odoo>
