<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_purchase_order_form_mercas" model="ir.ui.view">
        <field name="name">purchase.order.form.mercas</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <!-- Botón Purchase & Receive junto a Confirmar -->
            <button name="button_confirm" position="after">
                <button name="button_purchase_and_receive"
                        string="Purchase &amp; Receive"
                        type="object"
                        class="btn-primary"
                        data-hotkey="r"
                        invisible="state not in ('draft', 'sent')"/>
            </button>

            <!-- Campos auxiliares para dominio y visibilidad de columnas -->
            <xpath expr="//field[@name='order_line']" position="before">
                <field name="mercas_is_box_return" invisible="1"/>
                <field name="mercas_box_categ_ids" invisible="1"/>
                <field name="mercas_origin_country" invisible="1"/>
                <field name="mercas_origin_state" invisible="1"/>
            </xpath>

            <!-- Dominio en lot_id: solo lotes sin proveedor o del mismo proveedor y mismo producto -->
            <xpath expr="//field[@name='order_line']/list/field[@name='lot_id']"
                   position="attributes">
                <attribute name="domain">
                    [('product_id', '=', product_id), '|', ('partner_id', '=', False), ('partner_id', '=', parent.partner_id)]
                </attribute>
            </xpath>

            <!-- Columnas Cajas y Caja después de la cantidad -->
            <xpath expr="//field[@name='order_line']/list/field[@name='product_qty']"
                   position="after">
                <field name="box_qty" optional="show"/>
                <field name="box_product_id"
                       optional="show"
                       domain="[('categ_id', 'in', parent.mercas_box_categ_ids)] if parent.mercas_box_categ_ids else []"/>
            </xpath>

            <!-- Columnas país y provincia de origen -->
            <xpath expr="//field[@name='order_line']/list/field[@name='product_id']"
                   position="after">
                <field name="origin_country_id"
                       column_invisible="not parent.mercas_origin_country"
                       optional="show"/>
                <field name="origin_state_id"
                       column_invisible="not parent.mercas_origin_state"
                       optional="show"/>
            </xpath>

        </field>
    </record>

</odoo>
