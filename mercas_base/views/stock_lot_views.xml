<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_stock_lot_form_mercas" model="ir.ui.view">
        <field name="name">stock.lot.form.mercas</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="arch" type="xml">

            <!-- Botón de acción en el header -->
            <xpath expr="//sheet" position="before">
                <header>
                    <button
                        name="action_create_supplier_invoices"
                        string="Facturar lote"
                        type="object"
                        class="btn-primary"
                        invisible="not completed or supplier_invoice_id"
                    />
                </header>
            </xpath>

            <!-- Smart button factura proveedor -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_view_supplier_invoice"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-pencil-square-o"
                    invisible="not supplier_invoice_id"
                >
                    <div class="o_stat_info">
                        <span class="o_stat_text">Factura<br/>proveedor</span>
                    </div>
                </button>
            </xpath>

            <!-- Campos de origen en el header del formulario estándar -->
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="partner_id"/>
            </xpath>
            <xpath expr="//field[@name='location_id']" position="after">
                <field name="origin_country_id"/>
                <field name="origin_state_id"/>
            </xpath>

            <!-- Notebook de trazabilidad al final del sheet -->
            <xpath expr="//sheet" position="inside">
                <notebook>
                    <page string="General" name="mercas_general">
                        <field name="can_edit_margin" invisible="1"/>
                        <group>
                            <group string="Cantidades">
                                <field name="purchase_kg" readonly="1"/>
                                <field name="sale_kg" readonly="1"/>
                                <field name="scrap_kg" readonly="1"/>
                                <field name="product_qty" readonly="1"/>
                            </group>
                            <group string="Liquidación">
                                <field name="sale_amount" readonly="1"/>
                                <field name="mercas_margin" readonly="not can_edit_margin"/>
                                <field name="supplier_amount" readonly="1"/>
                                <field name="supplier_price_kg" readonly="1"/>
                                <field name="margin" readonly="1"/>
                                <field name="supplier_invoice_id" readonly="1"/>
                            </group>
                        </group>
                    </page>
                    <page string="Compras" name="purchase_lines">
                        <field name="purchase_line_ids" readonly="1" no_open="0">
                            <list>
                                <field name="order_id" string="Pedido"/>
                                <field name="product_id"/>
                                <field name="product_qty" string="Cantidad"/>
                                <field name="price_unit" string="Precio propuesto"/>
                                <field name="currency_id" column_invisible="1"/>
                            </list>
                        </field>
                    </page>
                    <page string="Ventas" name="sale_lines">
                        <field name="sale_line_ids" readonly="1" no_open="0">
                            <list>
                                <field name="order_id" string="Pedido"/>
                                <field name="product_id"/>
                                <field name="product_uom_qty" string="Cantidad"/>
                                <field name="price_unit" string="Precio conseguido"/>
                                <field name="currency_id" column_invisible="1"/>
                            </list>
                        </field>
                    </page>
                    <page string="F.Proveedor" name="supplier_invoice_lines">
                        <field name="supplier_invoice_line_ids" readonly="1" no_open="0">
                            <list>
                                <field name="move_id" string="Factura"/>
                                <field name="partner_id"/>
                                <field name="name" string="Descripción"/>
                                <field name="quantity"/>
                                <field name="price_unit"/>
                                <field name="price_subtotal"/>
                                <field name="currency_id" column_invisible="1"/>
                            </list>
                        </field>
                    </page>
                    <page string="F.Cliente" name="customer_invoice_lines">
                        <field name="customer_invoice_line_ids" readonly="1" no_open="0">
                            <list>
                                <field name="move_id" string="Factura"/>
                                <field name="partner_id"/>
                                <field name="name" string="Descripción"/>
                                <field name="quantity"/>
                                <field name="price_unit"/>
                                <field name="price_subtotal"/>
                                <field name="currency_id" column_invisible="1"/>
                            </list>
                        </field>
                    </page>
                    <page string="Desecho" name="scrap_lines">
                        <field name="scrap_line_ids" readonly="1" no_open="0">
                            <list>
                                <field name="name" string="Referencia"/>
                                <field name="product_id"/>
                                <field name="scrap_qty" string="Cantidad"/>
                                <field name="product_uom_id" string="UdM"/>
                                <field name="location_id"/>
                                <field name="date_done" string="Fecha"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </xpath>

        </field>
    </record>


    <record id="view_stock_lot_list_mercas" model="ir.ui.view">
        <field name="name">stock.lot.list.mercas</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list/field[@name='product_id']" position="after">
                <field name="partner_id" optional="show"/>
            </xpath>
            <xpath expr="//list/field[last()]" position="after">
                <field name="completed" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_stock_lot_search_mercas" model="ir.ui.view">
        <field name="name">stock.lot.search.mercas</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.search_product_lot_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search/field[1]" position="before">
                <field name="partner_id"/>
            </xpath>
            <xpath expr="//search" position="inside">
                <separator/>
                <filter
                    string="Completados no facturados"
                    name="completed_not_invoiced"
                    domain="[('completed', '=', True), ('supplier_invoice_id', '=', False)]"
                />
                <filter
                    string="Completado"
                    name="completed"
                    domain="[('completed', '=', True)]"
                />
                <separator/>
                <filter
                    string="Proveedor"
                    name="group_partner_id"
                    context="{'group_by': 'partner_id'}"
                />
            </xpath>
        </field>
    </record>


    <record id="action_mercas_lotes" model="ir.actions.act_window">
        <field name="name">Lotes</field>
        <field name="res_model">stock.lot</field>
        <field name="view_mode">list,form</field>
        <field name="context">{"search_default_completed_not_invoiced": 1}</field>
    </record>

    <record id="action_lot_create_supplier_invoices" model="ir.actions.server">
        <field name="name">Crear facturas proveedor</field>
        <field name="model_id" ref="stock.model_stock_lot"/>
        <field name="binding_model_id" ref="stock.model_stock_lot"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_create_supplier_invoices()</field>
    </record>

</odoo>
